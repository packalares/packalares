FROM golang:1.22-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bfl ./cmd/bfl

FROM alpine:3.19
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /bfl /usr/local/bin/bfl

EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/bfl"]
