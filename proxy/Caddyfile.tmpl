# Packalares Caddyfile template
# Processed by envsubst with: USER_ZONE, USERNAME, NODE_IP, AUTH_SERVICE
#
# Replaces: L4 proxy, BFL nginx, OpenResty, Lua scripts, token_auth

{
	# Listen on all interfaces (hostNetwork mode)
	http_port 80
	https_port 443

	# Self-signed certs — works with both IP and hostname
	local_certs
	auto_https disable_redirects
}

# ============================================================
# Snippet: forward auth to Authelia
# ============================================================
(authelia) {
	forward_auth ${AUTH_SERVICE} {
		uri /api/verify?rd=https://auth.${USER_ZONE}/
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
	}
}

# ============================================================
# Auth portal — Authelia UI
# ============================================================
auth.${USER_ZONE}, https://auth.${USER_ZONE} {
	tls internal

	reverse_proxy authelia-svc.packalares-auth.svc.cluster.local:9091
}

# ============================================================
# Desktop — main frontend
# ============================================================
desktop.${USER_ZONE}, https://desktop.${USER_ZONE} {
	tls internal

	import authelia

	reverse_proxy desktop-svc.user-space-${USERNAME}.svc.cluster.local:80
}

# ============================================================
# Settings
# ============================================================
settings.${USER_ZONE}, https://settings.${USER_ZONE} {
	tls internal

	import authelia

	reverse_proxy settings-svc.user-space-${USERNAME}.svc.cluster.local:80
}

# ============================================================
# Market / App Store
# ============================================================
market.${USER_ZONE}, https://market.${USER_ZONE} {
	tls internal

	import authelia

	reverse_proxy market-svc.user-space-${USERNAME}.svc.cluster.local:80
}

# ============================================================
# Files
# ============================================================
files.${USER_ZONE}, https://files.${USER_ZONE} {
	tls internal

	import authelia

	reverse_proxy files-svc.user-space-${USERNAME}.svc.cluster.local:80
}

# ============================================================
# Vault / Secrets
# ============================================================
vault.${USER_ZONE}, https://vault.${USER_ZONE} {
	tls internal

	import authelia

	reverse_proxy vault-svc.user-space-${USERNAME}.svc.cluster.local:80
}

# ============================================================
# API — system-server (no auth, uses its own tokens)
# ============================================================
api.${USER_ZONE}, https://api.${USER_ZONE} {
	tls internal

	reverse_proxy system-server.user-space-${USERNAME}.svc.cluster.local:80
}

# ============================================================
# BFL — backend for launcher (internal API)
# ============================================================
bfl.${USER_ZONE}, https://bfl.${USER_ZONE} {
	tls internal

	reverse_proxy bfl.user-space-${USERNAME}.svc.cluster.local:80
}

# ============================================================
# Wildcard — catch-all for user-installed apps
# Apps are routed by subdomain: {app}.USER_ZONE
# ============================================================
*.${USER_ZONE}, https://*.${USER_ZONE} {
	tls internal

	import authelia

	# Extract app name from subdomain: "foo.laurs.olares.local" → "foo"
	map {http.request.host} {app_name} {
		~"^([^.]+)\.(.+)$"  "${1}"
		default              "unknown"
	}

	reverse_proxy {app_name}-svc.user-space-${USERNAME}.svc.cluster.local:80
}

# ============================================================
# IP/bare access — path-based routing
# Useful when DNS is not configured; user hits https://NODE_IP
# ============================================================
${NODE_IP}, https://${NODE_IP} {
	tls internal

	# Path-based routes for core services
	handle /desktop/* {
		uri strip_prefix /desktop
		import authelia
		reverse_proxy desktop-svc.user-space-${USERNAME}.svc.cluster.local:80
	}

	handle /market/* {
		uri strip_prefix /market
		import authelia
		reverse_proxy market-svc.user-space-${USERNAME}.svc.cluster.local:80
	}

	handle /settings/* {
		uri strip_prefix /settings
		import authelia
		reverse_proxy settings-svc.user-space-${USERNAME}.svc.cluster.local:80
	}

	handle /files/* {
		uri strip_prefix /files
		import authelia
		reverse_proxy files-svc.user-space-${USERNAME}.svc.cluster.local:80
	}

	handle /api/* {
		uri strip_prefix /api
		reverse_proxy system-server.user-space-${USERNAME}.svc.cluster.local:80
	}

	handle /auth/* {
		uri strip_prefix /auth
		reverse_proxy authelia-svc.packalares-auth.svc.cluster.local:9091
	}

	# Default: redirect to desktop
	handle {
		redir /desktop/ permanent
	}
}

# ============================================================
# Fallback — anything else gets a 404
# ============================================================
:80, :443 {
	tls internal
	respond "Not Found" 404
}
