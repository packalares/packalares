FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /l4proxy ./cmd/l4proxy

FROM alpine:3.19
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /l4proxy /usr/local/bin/l4proxy

EXPOSE 443
ENTRYPOINT ["/usr/local/bin/l4proxy"]
LABEL org.opencontainers.image.description="L4 proxy — TCP/UDP layer 4 proxy for non-HTTP service routing"
