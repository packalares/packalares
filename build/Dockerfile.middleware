FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /middleware ./cmd/middleware

FROM alpine:3.19
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /middleware /usr/local/bin/middleware

ENTRYPOINT ["/usr/local/bin/middleware"]
