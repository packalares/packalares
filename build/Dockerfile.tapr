FROM golang:1.25-alpine AS builder
RUN apk add --no-cache git
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /tapr ./cmd/tapr

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /tapr /usr/local/bin/tapr
EXPOSE 8080
CMD ["tapr"]
