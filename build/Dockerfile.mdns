FROM golang:1.25-alpine AS builder
RUN apk add --no-cache git
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /mdns-agent ./cmd/mdns

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /mdns-agent /usr/local/bin/mdns-agent
ENTRYPOINT ["/usr/local/bin/mdns-agent"]
